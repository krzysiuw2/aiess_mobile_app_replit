# Supabase Configuration (REQUIRED for auth + edge function proxying)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Sign-In (Optional - email/password works without this)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id

# NOTE: InfluxDB and AWS secrets are stored in Supabase Edge Function Secrets.
# They are NEVER exposed in the client bundle.
