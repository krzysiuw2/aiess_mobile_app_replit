# Supabase Configuration (REQUIRED for auth)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# InfluxDB Configuration (REQUIRED for live data & analytics)
EXPO_PUBLIC_INFLUX_URL=https://your-influxdb-url.com
EXPO_PUBLIC_INFLUX_ORG=your-org-name
EXPO_PUBLIC_INFLUX_TOKEN=your-read-token-here

# AWS API Gateway (REQUIRED for schedule rules)
EXPO_PUBLIC_AWS_ENDPOINT=https://your-api-gateway-url.execute-api.region.amazonaws.com
EXPO_PUBLIC_AWS_API_KEY=your-api-key-here

# Google Sign-In (Optional - email/password works without this)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id
