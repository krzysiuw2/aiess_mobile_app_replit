{
  "expo": {
    "name": "AIESS",
    "slug": "aiess-energy-core",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/a-icon.png",
    "scheme": "aiess",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aiess.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSSpeechRecognitionUsageDescription": "Allow $(PRODUCT_NAME) to use speech recognition.",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to use the microphone."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#008cff"
      },
      "package": "com.aiess.mobile",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://aiess.app/"
        }
      ],
      [
        "expo-asset",
        {
          "assets": [
            "./assets/dashboard",
            "./assets/intro_animation"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "newArchEnabled": false
          },
          "android": {
            "newArchEnabled": false
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      "expo-speech-recognition",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "7876f371-52f5-4f41-923d-bc1ec284b2a9"
      },
      "router": {
        "origin": "https://aiess.app/"
      }
    },
    "owner": "kdub49"
  }
}
